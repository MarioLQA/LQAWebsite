          <div class="text-sm text-text-main/50 mt-1" data-key-stat-de="Branchen" data-key-stat-en="Industries">Branchen</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== PROJECTS ======== -->
  <section id="projects" class="py-28 px-6 relative">
    <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 0%, rgba(0,229,170,0.02) 50%, transparent 100%); pointer-events:none;"></div>
    <div class="max-w-4xl mx-auto relative z-10">
      <div class="text-center mb-16 reveal">
        <div class="section-divider"></div>
        <h2 class="text-3xl md:text-4xl font-bold mt-4 mb-4" data-key="projects.title">Projekte</h2>
        <p class="text-text-main/60" data-key="projects.sub">Ausgewählte Projektreferenzen aus meiner freiberuflichen Tätigkeit.</p>
      </div>

      <div class="space-y-5">
        {projects.map((project) => (
          <div class="project-card card-glow rounded-2xl bg-white/[0.02] overflow-hidden reveal">
            <div class="p-6 md:p-8">

              <!-- Header row: industry tag + period -->
              <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
                <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full" style="background: rgba(0,229,170,0.1); border: 1px solid rgba(0,229,170,0.3); color: #00E5AA; letter-spacing: 0.06em;">
                  {project.industryTag}
                </span>
                <span class="text-xs text-text-main/40">
                  <span data-show-lang="de">{project.periodDe}</span>
                  <span data-show-lang="en" class="hidden">{project.periodEn}</span>
                </span>
              </div>

              <!-- Company name -->
              <h3 class="text-lg font-bold text-text-main mb-3">{project.company}</h3>

              <!-- Teaser -->
              <p class="text-text-main/70 text-sm leading-relaxed">
                <span data-show-lang="de">{project.teaserDe}</span>
                <span data-show-lang="en" class="hidden">{project.teaserEn}</span>
              </p>

              <!-- Expandable body -->
              <div class="project-body">
                <div class="pt-4 space-y-3">
                  <div data-show-lang="de" class="space-y-3">
                    {project.bodyDe.map((para) => (
                      <p class="text-text-main/65 text-sm leading-relaxed">{para}</p>
                    ))}
                  </div>
                  <div data-show-lang="en" class="hidden space-y-3">
                    {project.bodyEn.map((para) => (
                      <p class="text-text-main/65 text-sm leading-relaxed">{para}</p>
                    ))}
                  </div>
                </div>
              </div>

              <!-- Footer: tags + toggle button -->
              <div class="flex flex-wrap items-center justify-between gap-3 mt-5 pt-4 border-t border-white/5">
                <div class="flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="text-xs px-2.5 py-1 rounded-full" style="background: rgba(41,121,255,0.1); border: 1px solid rgba(41,121,255,0.25); color: rgba(232,244,255,0.7);">{tag}</span>
                  ))}
                </div>
                <button
                  onclick="toggleProject(this)"
                  class="read-more-btn text-sm font-medium text-blue-primary hover:text-green-accent transition-colors flex items-center gap-1.5 flex-shrink-0"
                >
                  <span>
                    <span class="more-text">
                      <span data-show-lang="de">Mehr lesen</span>
                      <span data-show-lang="en" class="hidden">Read more</span>
                    </span>
                    <span class="less-text">
                      <span data-show-lang="de">Weniger</span>
                      <span data-show-lang="en" class="hidden">Show less</span>
                    </span>
                  </span>
                  <svg class="chevron-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </button>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======== TECH STACK ======== -->
  <section id="stack" class="py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <div class="section-divider"></div>
        <h2 class="text-3xl md:text-4xl font-bold mt-4 mb-4" data-key="stack.title">Tech Stack</h2>
        <p class="text-text-main/60" data-key="stack.sub">Bewährte Tools für moderne Qualitätssicherung.</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-5 reveal">
        {techStack.map((tool) => (
          <div class="tech-chip">
            <Fragment set:html={tool.svg} />
            <span class="text-sm font-medium text-text-main/80 text-center">{tool.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======== CONTACT ======== -->
  <section id="contact" class="py-28 px-6 relative">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at center bottom, rgba(0,229,170,0.04) 0%, transparent 70%); pointer-events:none;"></div>
    <div class="max-w-2xl mx-auto relative z-10">
      <div class="text-center mb-14 reveal">
        <div class="section-divider"></div>
        <h2 class="text-3xl md:text-4xl font-bold mt-4 mb-4" data-key="contact.title">Kontakt</h2>
        <p class="text-text-main/60" data-key="contact.sub">Bereit für Ihr nächstes Projekt? Schreiben Sie mir.</p>
      </div>

      <!-- Contact form -->
      <form
        action="mailto:mario@lqa-consulting.com"
        method="POST"
        enctype="text/plain"
        class="space-y-5 reveal card-glow rounded-2xl p-8 bg-white/[0.02]"
      >
        <div>
          <label class="block text-sm text-text-main/60 mb-2" data-key="contact.name">Name</label>
          <input type="text" name="name" class="form-input" placeholder="Max Mustermann" required data-placeholder-de="Max Mustermann" data-placeholder-en="John Doe" />
        </div>
        <div>
          <label class="block text-sm text-text-main/60 mb-2" data-key="contact.email">E-Mail</label>
          <input type="email" name="email" class="form-input" placeholder="max@example.com" required />
        </div>
        <div>
          <label class="block text-sm text-text-main/60 mb-2" data-key="contact.message">Nachricht</label>
          <textarea name="message" rows="5" class="form-input resize-none" placeholder="Beschreiben Sie Ihr Projekt…" required data-placeholder-de="Beschreiben Sie Ihr Projekt…" data-placeholder-en="Describe your project…"></textarea>
        </div>
        <button type="submit" class="btn-cta w-full text-center" data-key="contact.send">Senden</button>
      </form>

      <!-- Links -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mt-10 reveal">
        <a
          href="https://www.linkedin.com/in/mario-lirsch"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 text-text-main/60 hover:text-blue-primary transition-colors"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span class="text-sm" data-key="contact.linkedin">LinkedIn-Profil</span>
        </a>

        <a
          href="mailto:mario@lqa-consulting.com"
          class="flex items-center gap-3 text-text-main/60 hover:text-green-accent transition-colors"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <span class="text-sm" data-key="contact.emaillink">E-Mail schreiben</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ======== FOOTER ======== -->
  <footer class="border-t border-white/5 py-10 px-6">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <svg viewBox="0 0 80 80" width="28" height="28" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="ft-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#2979FF"/>
              <stop offset="100%" stop-color="#00E5AA"/>
            </linearGradient>
          </defs>
          <polygon points="40,8 64,21 64,47 40,60 16,47 16,21" fill="none" stroke="url(#ft-grad)" stroke-width="2"/>
        </svg>
        <span class="text-sm text-text-main/40" data-key="footer.copy">© 2025 Lirsch QA Consulting Ltd. · Zypern</span>
      </div>
      <span class="text-sm text-text-main/30 italic" data-key="footer.tagline">Qualität ist kein Zufall.</span>
    </div>
  </footer>

</body>

<!-- ======== SCRIPTS ======== -->
<script define:vars={{ tDE: t.de, tEN: t.en }}>
  // ---- Translations ----
  const translations = { de: tDE, en: tEN };
  let currentLang = 'de';

  function getNestedValue(obj, key) {
    return key.split('.').reduce((o, k) => (o ? o[k] : undefined), obj);
  }

  function applyTranslations(lang) {
    const t = translations[lang];
    currentLang = lang;

    // Update html lang attr
    document.documentElement.lang = lang;

    // Text nodes
    document.querySelectorAll('[data-key]').forEach(el => {
      const val = getNestedValue(t, el.dataset.key);
      if (val) el.textContent = val;
    });

    // List items
    document.querySelectorAll('[data-key-list]').forEach(ul => {
      const items = getNestedValue(t, ul.dataset.keyList);
      if (!items) return;
      const dots = ul.querySelectorAll('li');
      dots.forEach((li, i) => {
        const dot = li.querySelector('span');
        li.textContent = '';
        if (dot) li.appendChild(dot);
        li.append(' ' + items[i]);
      });
    });

    // Stat labels
    document.querySelectorAll('[data-key-stat-de]').forEach(el => {
      el.textContent = el.dataset[`keyStatDe`];
    });
    if (lang === 'en') {
      document.querySelectorAll('[data-key-stat-de]').forEach(el => {
        el.textContent = el.dataset[`keyStatEn`];
      });
    }

    // Placeholder text
    document.querySelectorAll('[data-placeholder-de]').forEach(el => {
      el.placeholder = el.dataset[`placeholder${lang.charAt(0).toUpperCase() + lang.slice(1)}`] || el.dataset.placeholderDe;
    });

    // Show/hide language-specific content (data-show-lang)
    document.querySelectorAll('[data-show-lang]').forEach(el => {
      el.classList.toggle('hidden', el.dataset.showLang !== lang);
    });

    // Update lang buttons
    document.querySelectorAll('#btn-de, #btn-de-m').forEach(b => b.classList.toggle('active', lang === 'de'));
    document.querySelectorAll('#btn-en, #btn-en-m').forEach(b => b.classList.toggle('active', lang === 'en'));

    // Update meta
    const metaDesc = document.querySelector('meta[name="description"]');
    if (lang === 'en' && metaDesc) {
      metaDesc.content = 'Freelance QA Engineer with 6+ years of experience. Test analysis, test strategy and automation with Cypress, Selenium & Appium.';
      document.title = 'Mario Lirsch – Freelance QA Engineer | LQA Consulting';
    } else if (metaDesc) {
      metaDesc.content = 'Freiberuflicher QA-Engineer mit 6+ Jahren Erfahrung. Testanalyse, Teststrategie und Testautomatisierung mit Cypress, Selenium & Appium.';
      document.title = 'Mario Lirsch – Freelance QA Engineer | LQA Consulting';
    }
  }

  window.setLang = function(lang) {
    applyTranslations(lang);
    try { localStorage.setItem('lqa-lang', lang); } catch(e) {}
  };

  // ---- Project card expand/collapse ----
  window.toggleProject = function(btn) {
    const card = btn.closest('.project-card');
    card.classList.toggle('expanded');
  };

  // ---- Nav scroll effect ----
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // ---- Mobile menu ----
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
  });
  window.closeMobileMenu = function() {
    mobileMenu.classList.add('hidden');
  };

  // ---- Scroll reveal ----
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // ---- Init language ----
  (function init() {
    let lang = 'de';
    try { lang = localStorage.getItem('lqa-lang') || 'de'; } catch(e) {}
    if (lang !== 'de') applyTranslations(lang);
  })();
</script>

</html>
