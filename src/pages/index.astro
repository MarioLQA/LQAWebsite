---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- DE Meta (default) -->
  <title>Mario Lirsch – Freelance QA Engineer | LQA Consulting</title>
  <meta name="description" content="Freiberuflicher QA-Engineer mit 6+ Jahren Erfahrung. Testanalyse, Teststrategie und Testautomatisierung mit Cypress, Selenium & Appium." />
  <meta name="keywords" content="QA Consulting, Testautomatisierung, Teststrategie, Cypress, Selenium, Appium, ISTQB, Freelancer, Mario Lirsch" />

  <!-- EN Meta (in JSON-LD alternate) -->
  <link rel="alternate" hreflang="en" href="?lang=en" />
  <link rel="alternate" hreflang="de" href="?lang=de" />

  <!-- OG -->
  <meta property="og:title" content="Mario Lirsch – Freelance QA Engineer | LQA Consulting" />
  <meta property="og:description" content="Freiberuflicher QA-Engineer mit 6+ Jahren Erfahrung. Testanalyse, Teststrategie und Testautomatisierung mit Cypress, Selenium & Appium." />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:locale:alternate" content="en_GB" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Lirsch QA Consulting Ltd.",
    "description": "QA Consulting — Testanalyse, Teststrategie & Testautomatisierung",
    "address": { "@type": "PostalAddress", "addressCountry": "CY" },
    "serviceType": ["Software Testing", "Test Automation", "QA Consulting"]
  }
  </script>

  <!-- Preload font hint -->
  <style>
    body { font-family: "Segoe UI", system-ui, sans-serif; }
  </style>
</head>

<body class="bg-bg text-text-main antialiased overflow-x-hidden">

  <!-- ======== NAVIGATION ======== -->
  <nav id="nav" class="fixed top-0 left-0 right-0 z-50 px-6 py-4">
    <div class="max-w-6xl mx-auto flex items-center justify-between">

      <!-- Logo -->
      <a href="#hero" class="flex items-center gap-3 group">
        <svg viewBox="0 0 80 80" width="44" height="44" xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0">
          <defs>
            <linearGradient id="nav-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#2979FF" />
              <stop offset="100%" stop-color="#00E5AA" />
            </linearGradient>
            <linearGradient id="nav-fill" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#2979FF" stop-opacity="0.18" />
              <stop offset="100%" stop-color="#00E5AA" stop-opacity="0.07" />
            </linearGradient>
          </defs>
          <polygon points="40,8 64,21 64,47 40,60 16,47 16,21" fill="url(#nav-fill)" stroke="url(#nav-grad)" stroke-width="2"/>
          <line x1="26" y1="22" x2="26" y2="46" stroke="#2979FF" stroke-width="4" stroke-linecap="square"/>
          <line x1="26" y1="46" x2="40" y2="46" stroke="#2979FF" stroke-width="4" stroke-linecap="square"/>
          <circle cx="46" cy="32" r="11" fill="none" stroke="#00E5AA" stroke-width="2.5"/>
          <line x1="53" y1="40" x2="59" y2="47" stroke="#00E5AA" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="40" cy="8" r="2.2" fill="#2979FF"/>
          <circle cx="64" cy="47" r="2.2" fill="#00E5AA"/>
          <circle cx="16" cy="21" r="2.2" fill="#2979FF" opacity="0.5"/>
        </svg>
        <div class="flex flex-col leading-tight">
          <span class="font-bold text-base tracking-wide text-text-main">LQA Consulting</span>
          <span class="text-xs text-text-main/40 tracking-wider">QUALITY ASSURANCE</span>
        </div>
      </a>

      <!-- Nav links + lang switcher (desktop) -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#services" class="nav-link text-sm text-text-main/70 hover:text-green-accent transition-colors" data-key="nav.services">Leistungen</a>
        <a href="#experience" class="nav-link text-sm text-text-main/70 hover:text-green-accent transition-colors" data-key="nav.experience">Erfahrung</a>
        <a href="#stack" class="nav-link text-sm text-text-main/70 hover:text-green-accent transition-colors" data-key="nav.stack">Stack</a>
        <a href="#contact" class="nav-link text-sm text-text-main/70 hover:text-green-accent transition-colors" data-key="nav.contact">Kontakt</a>

        <!-- Language switcher -->
        <div class="flex items-center gap-1 border border-white/10 rounded-md px-1">
          <button id="btn-de" class="lang-btn active" onclick="setLang('de')">DE</button>
          <span class="text-white/20 text-xs">|</span>
          <button id="btn-en" class="lang-btn" onclick="setLang('en')">EN</button>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button id="menu-btn" class="md:hidden text-text-main/70 hover:text-text-main" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-white/10">
      <div class="max-w-6xl mx-auto flex flex-col gap-4 pt-4 px-2">
        <a href="#services" class="nav-link text-sm text-text-main/70" data-key="nav.services" onclick="closeMobileMenu()">Leistungen</a>
        <a href="#experience" class="nav-link text-sm text-text-main/70" data-key="nav.experience" onclick="closeMobileMenu()">Erfahrung</a>
        <a href="#stack" class="nav-link text-sm text-text-main/70" data-key="nav.stack" onclick="closeMobileMenu()">Stack</a>
        <a href="#contact" class="nav-link text-sm text-text-main/70" data-key="nav.contact" onclick="closeMobileMenu()">Kontakt</a>
        <div class="flex items-center gap-2">
          <button id="btn-de-m" class="lang-btn active" onclick="setLang('de')">DE</button>
          <span class="text-white/20 text-xs">|</span>
          <button id="btn-en-m" class="lang-btn" onclick="setLang('en')">EN</button>
        </div>
      </div>
    </div>
  </nav>

  <!-- ======== HERO ======== -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden px-6 pt-20">
    <div class="hex-bg"></div>

    <!-- Decorative grid lines -->
    <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgba(41,121,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(41,121,255,0.04) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <div class="relative max-w-4xl mx-auto text-center z-10">
      <!-- Monogram large -->
      <div class="flex justify-center mb-10 reveal">
        <svg viewBox="0 0 80 80" width="100" height="100" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="hero-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#2979FF" />
              <stop offset="100%" stop-color="#00E5AA" />
            </linearGradient>
            <linearGradient id="hero-fill" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#2979FF" stop-opacity="0.18" />
              <stop offset="100%" stop-color="#00E5AA" stop-opacity="0.07" />
            </linearGradient>
          </defs>
          <polygon points="40,8 64,21 64,47 40,60 16,47 16,21" fill="url(#hero-fill)" stroke="url(#hero-grad)" stroke-width="2"/>
          <line x1="26" y1="22" x2="26" y2="46" stroke="#2979FF" stroke-width="4" stroke-linecap="square"/>
          <line x1="26" y1="46" x2="40" y2="46" stroke="#2979FF" stroke-width="4" stroke-linecap="square"/>
          <circle cx="46" cy="32" r="11" fill="none" stroke="#00E5AA" stroke-width="2.5"/>
          <line x1="53" y1="40" x2="59" y2="47" stroke="#00E5AA" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="40" cy="8" r="2.2" fill="#2979FF"/>
          <circle cx="64" cy="47" r="2.2" fill="#00E5AA"/>
          <circle cx="16" cy="21" r="2.2" fill="#2979FF" opacity="0.5"/>
        </svg>
      </div>

      <h1 class="reveal text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-tight">
        <span class="grad-text" data-key="hero.headline">Qualität ist kein Zufall.</span>
      </h1>

      <p class="reveal text-lg md:text-xl text-text-main/70 max-w-2xl mx-auto mb-10 leading-relaxed" data-key="hero.sub">
        Freiberuflicher QA-Engineer mit über 6 Jahren Erfahrung im manuellen und automatisierten Software-Testing für Web- und Mobile-Anwendungen. Als ISTQB-zertifizierter Test Analyst verbinde ich strukturierte Testanalyse mit moderner Testautomatisierung – in agilen Teams, remote und on-site.
      </p>

      <div class="reveal">
        <a href="#contact" class="btn-cta" data-key="hero.cta">Projekt anfragen</a>
      </div>

      <!-- Badges -->
      <div class="reveal flex flex-wrap justify-center gap-3 mt-8">
        <span class="badge" data-key="hero.badges.0">6+ Jahre Erfahrung</span>
        <span class="badge" data-key="hero.badges.1">ISTQB Foundation & Advanced</span>
        <span class="badge" data-key="hero.badges.2">Remote & On-site</span>
        <span class="badge" data-key="hero.badges.3">Agile / Scrum</span>
      </div>
    </div>

    <!-- Scroll indicator — anchored to section bottom -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40 pointer-events-none">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
        <rect x="1" y="1" width="14" height="22" rx="7" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="8" cy="7" r="2.5" fill="currentColor" class="animate-bounce"/>
      </svg>
    </div>
  </section>

  <!-- ======== SERVICES ======== -->
  <section id="services" class="py-28 px-6 relative">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <div class="section-divider"></div>
        <h2 class="text-3xl md:text-4xl font-bold mt-4" data-key="services.title">Leistungen</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">

        <!-- Card 1 -->
        <div class="card-glow rounded-2xl p-8 bg-white/[0.02] reveal">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(41,121,255,0.15);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2979FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 11l3 3L22 4"/>
                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold" data-key="services.card1.title">Testanalyse & Teststrategie</h3>
          </div>
          <p class="text-text-main/60 mb-6 leading-relaxed" data-key="services.card1.desc">
            Analyse funktionaler & nicht-funktionaler Anforderungen, risikobasierte Teststrategie und Testkonzepte – für vollständige Qualitätssicherung im gesamten SDLC.
          </p>
          <ul class="space-y-3" data-key-list="services.card1.items">
            <li class="flex items-center gap-3 text-sm text-text-main/75">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-primary flex-shrink-0"></span>
